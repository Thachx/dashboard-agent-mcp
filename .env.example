MCP_PORT=3001
MCP_HOST=127.0.0.1
# Comma-separated Host headers accepted by the HTTP server.
# Add host.docker.internal when an MCP client runs in Docker Desktop.
MCP_ALLOWED_HOSTS=127.0.0.1,localhost
# Browser-reachable base URL used in Markdown image results.
MCP_PUBLIC_BASE_URL=http://127.0.0.1:3001
DASHBOARD_PREVIEW_TTL_MS=86400000
DASHBOARD_PREVIEW_MAX_ENTRIES=100
DASHBOARD_AGENT_URL=http://127.0.0.1:2024
DASHBOARD_AGENT_ASSISTANT_ID=dashboard_agent
DASHBOARD_AGENT_TIMEOUT_MS=120000
DASHBOARD_AGENT_FIXTURE=false
